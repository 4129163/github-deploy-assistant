{
  "name": "github-deploy-assistant",
  "version": "2.0.0-i18n",
  "description": "GitHub 项目辅助安装程序 - 自动解读仓库并部署（多语言支持）",
  "main": "src/server/index.js",
  "bin": {
    "gada": "./src/cli/index.js",
    "gada-runtime": "./src/cli/with-runtime.js"
  },
  "scripts": {
    "start": "node server-i18n.js",
    "dev": "nodemon server-i18n.js",
    "start:original": "node src/server/index.js",
    "dev:original": "nodemon src/server/index.js",
    "cli": "node src/cli/index.js",
    "build": "echo 'Build complete'",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:p1": "jest test/integration --coverage",
    "test:p1-temp": "jest test/integration/temp-directory.test.js --coverage",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "test:full": "npm run test:coverage && npm run test:e2e",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "security-check": "npm audit",
    "ci": "npm run lint && npm run test && npm run build",
    "ci:p1": "npm run lint && npm run test:p1 && npm run test:e2e",
    "ui": "node server.js",
    "ui:dev": "nodemon server.js",
    "ui:i18n": "node server-i18n.js",
    "ui:i18n-dev": "nodemon server-i18n.js",
    "secure:init": "node scripts/migrate-secure.js",
    "secure:test": "node test-secure-storage.js",
    "secure:status": "node -e \"const storage = require('./src/utils/secure-storage'); console.log('安全存储状态:', storage.isInitialized() ? '已初始化' : '未初始化');\"",
    "secure:backup": "node -e \"const storage = require('./src/utils/secure-storage'); (async () => { const backupFile = await storage.backup('./secure-backup.json', process.env.MASTER_PASSWORD); console.log('备份完成:', backupFile); })();\"",
    "secure:health": "curl -s http://localhost:3000/api/health | jq . || curl -s http://localhost:3000/api/health",
    "type-check": "node scripts/type-check.js",
    "type-check:report": "node scripts/type-check.js --report",
    "type-check:jsdoc": "node scripts/type-check.js --jsdoc",
    "type-check:ci": "npm run type-check && npm run lint",
    "types": "tsc --noEmit --project tsconfig.json",
    "types:watch": "tsc --noEmit --project tsconfig.json --watch"
  },
  "keywords": [
    "github",
    "deploy",
    "assistant",
    "auto-install",
    "ai",
    "openai",
    "deepseek",
    "devops",
    "systemd",
    "launchd",
    "windows-service",
    "service-management",
    "process-daemon",
    "i18n",
    "internationalization",
    "multilingual",
    "localization"
  ],
  "author": "kai0339 <19106440339@163.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/kai0339/github-deploy-assistant.git"
  },
  "bugs": {
    "url": "https://gitee.com/kai0339/github-deploy-assistant/issues"
  },
  "homepage": "https://gitee.com/kai0339/github-deploy-assistant#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "body-parser": "^1.20.2",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "commander": "^9.4.1",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.1.1",
    "inquirer": "^8.2.6",
    "marked": "^11.1.0",
    "multer": "^1.4.5-lts.1",
    "node-ssh": "^13.2.0",
    "ora": "^5.4.1",
    "simple-git": "^3.21.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1",
    "sudo-prompt": "^9.2.1",
    "tcp-port-used": "^1.0.2",
    "uuid": "^9.0.1",
    "which": "^3.0.0",
    "winston": "^3.8.2",
    "ws": "^8.16.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "prettier": "^3.2.4",
    "supertest": "^6.3.3",
    "tmp-promise": "^3.0.3"
  }
}