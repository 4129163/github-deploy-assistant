{
  "name": "github-deploy-assistant",
  "version": "1.0.0",
  "description": "GitHub 项目辅助安装程序 - 自动解读仓库并部署",
  "main": "src/server/index.js",
  "bin": {
    "gada": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "nodemon src/server/index.js",
    "cli": "node src/cli/index.js",
    "build": "echo 'Build complete'",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "security-check": "npm audit",
    "ci": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "github",
    "deploy",
    "assistant",
    "auto-install",
    "ai",
    "openai",
    "deepseek"
  ],
  "author": "GitHub Deploy Assistant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/4129163/github-deploy-assistant.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.1.1",
    "inquirer": "^8.2.6",
    "marked": "^11.1.0",
    "multer": "^1.4.5-lts.1",
    "node-ssh": "^13.2.0",
    "ora": "^5.4.1",
    "semver": "^7.7.4",
    "simple-git": "^3.21.0",
    "sqlite3": "^6.0.1",
    "tcp-port-used": "^1.0.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.4",
    "supertest": "^6.3.3"
  }
}
