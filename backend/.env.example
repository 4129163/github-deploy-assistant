# 服务器配置
PORT=3000
ENVIRONMENT=development

# 数据库配置
DB_PATH=./data/gda.db

# GitHub API配置
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=owner/repository_name

# CORS配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 安全配置
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key_here

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 应用配置
APP_NAME=GitHub Deploy Assistant
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# 社区功能配置
ENABLE_COMMUNITY_FEATURES=true
ENABLE_GITHUB_SYNC=true
MAX_COMMENTS_PER_PAGE=50
MAX_ISSUES_PER_PAGE=100

# 环境信息收集配置
COLLECT_ENVIRONMENT_INFO=true
INCLUDE_SYSTEM_INFO=true
INCLUDE_NETWORK_INFO=false

# 如何获取GitHub Token:
# 1. 访问 https://github.com/settings/tokens
# 2. 点击 "Generate new token" (classic)
# 3. 选择权限：repo (完全控制私有仓库)
# 4. 复制生成的token到这里

# 如何设置GitHub仓库:
# 格式：用户名/仓库名 或 组织名/仓库名
# 例如：octocat/Hello-World