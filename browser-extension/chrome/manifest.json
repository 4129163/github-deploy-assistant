{
  "manifest_version": 3,
  "name": "GitHub Deploy Assistant (GADA)",
  "version": "1.0.0",
  "description": "在GitHub/Gitee仓库页面添加一键部署按钮，快速唤起本地GADA应用",
  "author": "kai0339 <19106440339@163.com>",
  "homepage_url": "https://gitee.com/kai0339/github-deploy-assistant",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  
  "host_permissions": [
    "http://localhost:3000/*",
    "https://github.com/*",
    "https://gitee.com/*"
  ],
  
  "background": {
    "service_worker": "../shared/scripts/background.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://gitee.com/*"
      ],
      "js": ["../shared/scripts/content.js"],
      "css": ["../shared/styles/inject.css"],
      "run_at": "document_end"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["../shared/styles/*"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "action": {
    "default_title": "GADA一键部署",
    "default_popup": "popup.html"
  },
  
  "options_page": "options.html",
  
  "minimum_chrome_version": "88"
}