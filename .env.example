# GitHub Deploy Assistant 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ============================================
# 服务器配置
# ============================================
PORT=3456
NODE_ENV=development
HOST=0.0.0.0

# ============================================
# 工作目录和权限
# ============================================
WORK_DIR=./workspace
ALLOW_AUTO_EXEC=true

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
MAX_LOG_SIZE_MB=20
MAX_LOG_DAYS=30
MAX_TOTAL_LOG_MB=200
ENABLE_JSON_LOG=false
ENABLE_REMOTE_LOG=false
REMOTE_LOG_URL=

# ============================================
# AI配置
# ============================================
DEFAULT_AI_PROVIDER=openai

# OpenAI配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# DeepSeek配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Gemini配置
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-pro

# Claude配置
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229

# 智谱AI配置
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4

# 通义千问配置
QWEN_API_KEY=your-qwen-api-key-here
QWEN_MODEL=qwen-max

# Moonshot配置
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_MODEL=moonshot-v1-8k

# ============================================
# 安全配置
# ============================================
# 生成强密钥：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GADA_SECRET_KEY=your-strong-secret-key-here-change-me
SESSION_SECRET=your-session-secret-here-change-me
JWT_SECRET=your-jwt-secret-here-change-me
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 缓存配置
# ============================================
LOG_CACHE_SIZE=200
LOG_CACHE_TTL=3600000
API_CACHE_TTL=300000

# ============================================
# 进程管理
# ============================================
PROCESS_RESTART_MAX_WAIT=10000
PROCESS_RESTART_DELAY=500
PROCESS_MONITOR_INTERVAL=30000

# ============================================
# 性能监控
# ============================================
PERFORMANCE_MONITOR_ENABLED=true
PERFORMANCE_SAMPLING_INTERVAL=60000

# ============================================
# GitHub配置
# ============================================
GITHUB_API_TIMEOUT=10000
GITHUB_RATE_LIMIT_WINDOW=60000
# GitHub个人访问令牌（用于提高API限制）
GITHUB_PERSONAL_TOKEN=your-github-token-here

# ============================================
# Webhook配置
# ============================================
# 生成Webhook Secret：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=your-webhook-secret-here-change-me
WEBHOOK_TIMEOUT=5000

# ============================================
# 文件上传配置
# ============================================
UPLOAD_MAX_SIZE=52428800
UPLOAD_ALLOWED_TYPES=.zip,.tar,.tar.gz,.tgz,.gz

# ============================================
# 备份配置
# ============================================
BACKUP_RETENTION_DAYS=7
BACKUP_MAX_COUNT=10
BACKUP_COMPRESS_LEVEL=6

# ============================================
# 健康检查配置
# ============================================
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# ============================================
# 邮件通知配置
# ============================================
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
NOTIFICATION_EMAIL=admin@example.com

# ============================================
# 调试配置
# ============================================
DEBUG_SQL=false
DEBUG_API=false
DEBUG_PERFORMANCE=false

# ============================================
# 数据库配置
# ============================================
# SQLite数据库路径（默认：./database/gada.db）
# DB_PATH=./database/gada.db

# ============================================
# 高级配置
# ============================================
# 自定义AI提供商URL
# CUSTOM_AI_PROVIDER_URL=https://your-custom-ai-service.com/v1
# CUSTOM_AI_MODEL=your-custom-model

# 代理配置（如果需要）
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# SSL配置（如果需要HTTPS）
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# ============================================
# 功能开关
# ============================================
# 启用/禁用特定功能
ENABLE_REMOTE_DEPLOYMENT=true
ENABLE_SHARING=true
ENABLE_WEBHOOKS=true
ENABLE_AI_ANALYSIS=true
ENABLE_AUTO_DEPLOY=true
ENABLE_BACKUP=true
ENABLE_HEALTH_CHECKS=true
ENABLE_PERFORMANCE_MONITORING=true