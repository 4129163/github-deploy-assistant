# =============================================================================
# GitHub Deploy Assistant (GADA) - 环境变量配置
# 复制此文件为 .env 并填写你的配置
# cp .env.example .env
# =============================================================================

# ── 服务配置 ──────────────────────────────────────────────────────────────────

# Web 服务端口（默认 3456，访问地址：http://localhost:3456）
PORT=3456

# 项目克隆目录（相对路径或绝对路径）
WORK_DIR=./workspace

# 是否允许自动执行命令
# true  = 自动安装模式可用（推荐，功能完整）
# false = 只生成教程，不自动运行任何命令（更安全）
ALLOW_AUTO_EXEC=true

# 克隆超时时间（毫秒，默认 2 分钟；大仓库可适当调大）
CLONE_TIMEOUT_MS=120000

# 日志级别（error / warn / info / debug）
LOG_LEVEL=info


# ── AI 配置 ───────────────────────────────────────────────────────────────────
# 至少配置一个 AI 提供商才能使用 AI 分析功能
# 也可以在 Web 界面的「AI 设置」页面配置，无需手动编辑此文件

# 默认使用的 AI 提供商（openai / deepseek / gemini / claude）
DEFAULT_AI_PROVIDER=openai

# OpenAI
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek（价格极低，推荐国内用户使用）
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude
# 获取地址：https://console.anthropic.com
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-3-haiku-20240307

# 自定义 OpenAI 兼容接口（中转站等）
# 在 Web 界面「AI 设置」→「添加自定义」中配置，无需在此填写
# CUSTOM_AI_BASE_URL=https://your-proxy.com/v1
# CUSTOM_AI_KEY=sk-xxx
# CUSTOM_AI_MODEL=gpt-4o
