# =============================================================================
# GitHub Deploy Assistant (GADA) 环境变量配置
# =============================================================================

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
PORT=3456
NODE_ENV=production

# -----------------------------------------------------------------------------
# AI 模型配置（至少配置一个，否则无法使用 AI 分析功能）
# 推荐：DeepSeek（价格低）或 OpenAI（效果好）
# -----------------------------------------------------------------------------

# OpenAI / ChatGPT
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# DeepSeek（推荐，价格便宜）
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-pro

# Anthropic Claude
# 获取地址: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-claude-api-key
CLAUDE_MODEL=claude-3-sonnet-20240229

# 月之暗面 Kimi
# 获取地址: https://platform.moonshot.cn
MOONSHOT_API_KEY=sk-your-moonshot-api-key
MOONSHOT_MODEL=moonshot-v1-8k

# 通义千问
# 获取地址: https://dashscope.aliyun.com
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_MODEL=qwen-turbo

# 默认使用的 AI 模型（填写上面配置的 key 名，如 openai/deepseek/gemini/claude/moonshot/qwen）
DEFAULT_AI_PROVIDER=deepseek

# -----------------------------------------------------------------------------
# GitHub 配置（可选，不填也能用，但有 API 频率限制）
# 获取地址: https://github.com/settings/tokens → 创建 token → 勾选 public_repo
# 注意：请勿将真实 token 提交到 git 仓库！
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# 部署配置
# -----------------------------------------------------------------------------
# 工作目录（用于克隆和部署项目，相对路径或绝对路径均可）
WORK_DIR=./workspace

# 是否允许自动执行命令（自动模式）
ALLOW_AUTO_EXEC=true

# 部署超时时间（毫秒），默认 600000（10分钟），大型项目可适当调大
DEPLOY_TIMEOUT_MS=600000

# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info

