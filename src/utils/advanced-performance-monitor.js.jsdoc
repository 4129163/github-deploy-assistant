/**
 * @file 高级性能监控模块
 * @module utils/advanced-performance-monitor
 * @description 扩展原有的性能监控，添加更多指标收集功能
 * @version 2.0.0
 * @license MIT
 */

/**
 * 请求队列深度指标
 * @typedef {Object} RequestQueueMetrics
 * @property {number} current - 当前队列深度
 * @property {number} max - 历史最大深度
 * @property {number} avg - 平均深度
 * @property {Array<QueueSample>} samples - 队列深度样本
 * @property {number} totalRequests - 总请求数
 */

/**
 * 队列深度样本
 * @typedef {Object} QueueSample
 * @property {number} timestamp - 时间戳
 * @property {number} depth - 队列深度
 */

/**
 * 事件循环延迟指标
 * @typedef {Object} EventLoopMetrics
 * @property {number} current - 当前延迟(ms)
 * @property {number} max - 最大延迟(ms)
 * @property {number} avg - 平均延迟(ms)
 * @property {Array<EventLoopSample>} samples - 延迟样本
 * @property {Array<EventLoopHistogram>} histograms - 延迟直方图
 */

/**
 * 事件循环样本
 * @typedef {Object} EventLoopSample
 * @property {number} timestamp - 时间戳
 * @property {number} delay - 延迟(ms)
 */

/**
 * 事件循环延迟直方图
 * @typedef {Object} EventLoopHistogram
 * @property {number} timestamp - 时间戳
 * @property {Object.<string, number>} bins - 延迟分布桶
 */

/**
 * 垃圾回收统计
 * @typedef {Object} GarbageCollectionStats
 * @property {number} totalCount - 总GC次数
 * @property {number} totalTime - 总GC时间(ms)
 * @property {Map<string, GCTypeStats>} byType - 按类型统计
 * @property {number} lastGcTime - 最后一次GC时间戳
 */

/**
 * GC类型统计
 * @typedef {Object} GCTypeStats
 * @property {number} count - 该类型GC次数
 * @property {number} totalTime - 该类型总GC时间(ms)
 */

/**
 * HTTP请求详情统计
 * @typedef {Object} HttpRequestDetails
 * @property {Map<number, number>} byStatusCode - 按状态码统计
 * @property {Map<string, number>} byContentType - 按内容类型统计
 * @property {Map<string, number>} byUserAgent - 按User-Agent统计
 * @property {Array<ResponseSizeSample>} responseSizes - 响应大小样本
 * @property {Array<RequestSizeSample>} requestSizes - 请求大小样本
 */

/**
 * 响应大小样本
 * @typedef {Object} ResponseSizeSample
 * @property {number} timestamp - 时间戳
 * @property {number} size - 响应大小(字节)
 * @property {string} path - 请求路径
 * @property {string} method - HTTP方法
 */

/**
 * 请求大小样本
 * @typedef {Object} RequestSizeSample
 * @property {number} timestamp - 时间戳
 * @property {number} size - 请求大小(字节)
 * @property {string} path - 请求路径
 * @property {string} method - HTTP方法
 */

/**
 * 数据库连接池状态
 * @typedef {Object} DatabasePoolStatus
 * @property {number} totalConnections - 总连接数
 * @property {number} activeConnections - 活跃连接数
 * @property {number} idleConnections - 空闲连接数
 * @property {number} waitingClients - 等待客户端数
 * @property {number} connectionErrors - 连接错误数
 */

/**
 * 缓存统计
 * @typedef {Object} CacheStats
 * @property {number} hits - 缓存命中次数
 * @property {number} misses - 缓存未命中次数
 * @property {number} hitRate - 缓存命中率(%)
 * @property {number} size - 当前缓存大小
 * @property {number} maxSize - 最大缓存大小
 * @property {number} evictions - 缓存驱逐次数
 */

/**
 * 业务指标
 * @typedef {Object} BusinessMetric
 * @property {Array<MetricSample>} values - 指标值样本
 * @property {Object} labels - 指标标签
 * @property {string} type - 指标值类型
 */

/**
 * 指标样本
 * @typedef {Object} MetricSample
 * @property {number} timestamp - 时间戳
 * @property {any} value - 指标值
 */

/**
 * 资源限制配置
 * @typedef {Object} ResourceLimits
 * @property {number} maxMemory - 最大内存使用率(%)
 * @property {number} maxEventLoopDelay - 最大事件循环延迟(ms)
 * @property {number} maxQueueDepth - 最大请求队列深度
 * @property {number} maxCpuUsage - 最大CPU使用率(%)
 */

/**
 * 高级性能监控配置
 * @typedef {Object} AdvancedMonitorConfig
 * @property {number} [samplingInterval=5000] - 采样间隔(ms)
 * @property {number} [maxSamples=720] - 最大样本数
 * @property {ResourceLimits} [resourceLimits] - 资源限制配置
 */

