 * @file AI 服务模块
 * @module services/ai
 * @description 提供多模型AI服务支持，包括自定义提供商配置
 * @version 2.0.0-i18n
 * @license MIT
 */

/**
 * AI提供商配置接口
 * @typedef {Object} AIProviderConfig
 * @property {string} name - 提供商名称
 * @property {string} baseURL - API基础URL
 * @property {string} apiKey - API密钥
 * @property {string[]} models - 支持的模型列表
 * @property {string} defaultModel - 默认模型
 * @property {boolean} builtin - 是否为内置提供商
 */

/**
 * AI请求配置
 * @typedef {Object} AIRequestConfig
 * @property {string} provider - 提供商名称
 * @property {string} [model] - 模型名称
 * @property {string} prompt - 提示词
 * @property {number} [temperature=0.7] - 温度参数
 * @property {number} [maxTokens=2000] - 最大令牌数
 * @property {Object} [systemPrompt] - 系统提示
 * @property {boolean} [stream=false] - 是否流式响应
 */

/**
 * AI响应结果
 * @typedef {Object} AIResponse
 * @property {boolean} success - 是否成功
 * @property {string} content - AI生成的内容
 * @property {string} [error] - 错误信息
 * @property {Object} [metadata] - 元数据
 * @property {number} [tokens] - 使用的令牌数
 * @property {number} [latency] - 响应延迟(ms)
 */

/**
 * 项目分析结果
 * @typedef {Object} ProjectAnalysisResult
 * @property {string} projectType - 项目类型
 * @property {string} language - 主要语言
 * @property {string} framework - 框架
 * @property {Object} dependencies - 依赖分析
 * @property {Object} structure - 项目结构
 * @property {string[]} issues - 发现的问题
 * @property {string[]} recommendations - 建议
 * @property {Object} deploymentConfig - 部署配置
 */

/**
 * 部署脚本生成结果
 * @typedef {Object} DeploymentScriptResult
 * @property {string} script - 部署脚本内容
 * @property {Object} config - 配置信息
 * @property {string[]} prerequisites - 先决条件
 * @property {Object} environment - 环境变量
 * @property {string[]} commands - 命令列表
 */

// 内置AI提供商配置
const BUILTIN_PROVIDERS = {
  // OpenAI 配置
  openai: {
    name: 'OpenAI',
    baseURL: process.env.OPENAI_BASE_URL || 'https://api.openai.com/v1',
    apiKey: process.env.OPENAI_API_KEY,
    models: ['gpt-4o', 'gpt-4o-mini', 'gpt-4', 'gpt-3.5-turbo'],
    defaultModel: process.env.OPENAI_MODEL || 'gpt-4o',
    builtin: true
  },
  // 其他提供商配置...
};

