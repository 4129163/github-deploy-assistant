/**
 * 命令行界面配置选项
 * @typedef {Object} CliOptions
 * @property {boolean} [interactive=true] - 是否启用交互模式
 * @property {string} [logLevel='info'] - 日志级别
 * @property {string} [workDir] - 工作目录路径
 * @property {boolean} [skipWelcome=false] - 是否跳过欢迎信息
 */

/**
 * 项目分析配置
 * @typedef {Object} ProjectAnalysisConfig
 * @property {string} repoUrl - 仓库URL
 * @property {string} [branch='main'] - 分支名称
 * @property {boolean} [deepAnalysis=false] - 是否进行深度分析
 * @property {string[]} [analysisTypes] - 分析类型数组
 */

/**
 * 部署配置
 * @typedef {Object} DeploymentConfig
 * @property {string} projectId - 项目ID
 * @property {string} environment - 部署环境
 * @property {boolean} [autoDeploy=true] - 是否自动部署
 * @property {Object} [variables] - 环境变量
 */

/**
 * AI模型配置
 * @typedef {Object} AIConfig
 * @property {string} provider - AI提供商
 * @property {string} model - 模型名称
 * @property {string} apiKey - API密钥
 * @property {number} [temperature=0.7] - 温度参数
 */

