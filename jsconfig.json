{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "checkJs": true,
    "allowJs": true,
    "strict": false,
    "noEmit": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@utils/*": ["src/utils/*"],
      "@middleware/*": ["src/middleware/*"],
      "@routes/*": ["src/routes/*"],
      "@services/*": ["src/services/*"],
      "@types/*": ["types/*"]
    }
  },
  "include": [
    "src/**/*",
    "server.js",
    "server-i18n.js",
    "types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "public",
    "templates"
  ]
}